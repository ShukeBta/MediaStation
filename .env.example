# ============================================================
#  MediaStation 环境变量配置模板
#  用法: cp .env.example .env
#        修改下方标注了 ⚠️ 的必填项
# ============================================================

# ═══════════════════════════════════════════════════════════════
#  基础配置
# ═══════════════════════════════════════════════════════════════

# ── 服务端口 ──
# 服务对外暴露的端口（默认 3001）
MS_PORT=3001

# ── 安全配置 ──
# JWT 签名密钥（⚠️ 必须修改为随机字符串！）
# 生成方式: openssl rand -hex 32
APP_SECRET_KEY=please-change-this-to-a-random-string
# 调试模式（生产环境必须关闭）
APP_DEBUG=false

# ── 数据目录 ──
# 所有数据（数据库、缓存、转码临时文件）存储目录
DATA_DIR=./data

# ═══════════════════════════════════════════════════════════════
#  元数据源
# ═══════════════════════════════════════════════════════════════

# ── TMDb（⚠️ 必填） ──
# 申请地址: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key
# TMDb 语言
TMDB_LANGUAGE=zh-CN

# ── 豆瓣（可选，中文元数据补充） ──
# 登录豆瓣后，在控制台执行 document.cookie 获取
# DOUBAN_COOKIE=your-douban-cookie

# ── Bangumi（可选，动漫元数据） ──
# 申请地址: https://bgm.tv/OAuth
# BANGUMI_TOKEN=your-bangumi-token

# ── 音乐（元） ──
# 音乐刮削源
# MUSIC_BRAINZ_ENABLED=true

# ═══════════════════════════════════════════════════════════════
#  AI 智能功能（可选）
# ═══════════════════════════════════════════════════════════════

# ── OpenAI 兼容 API（用于 AI 刮削） ──
# 支持 Ollama / vLLM / LM Studio / Groq 等
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=2000
# AI_SCRAPE_ENABLED=false

# ── 本地 Ollama（可选） ──
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ═══════════════════════════════════════════════════════════════
#  数据库配置
# ═══════════════════════════════════════════════════════════════

# ── SQLite（默认，零配置） ──
# 无需配置，直接使用 DATA_DIR/mediastation.db

# ── PostgreSQL（可选，大规模部署时使用） ──
# DATABASE_URL=postgresql+asyncpg://mediastation:mediastation123@postgres:5432/mediastation
# 数据库连接池大小（默认 10）
# DB_POOL_SIZE=10
# 最大溢出连接数（默认 20）
# DB_MAX_OVERFLOW=20

# ── Redis（可选，缓存加速） ──
# REDIS_URL=redis://redis:6379/0

# ═══════════════════════════════════════════════════════════════
#  下载客户端配置
# ═══════════════════════════════════════════════════════════════

# ── qBittorrent（最常用） ──
QB_HOST=http://localhost:8080
QB_USERNAME=admin
QB_PASSWORD=adminadmin

# ── Transmission（替代方案） ──
# TR_HOST=http://localhost:9091
# TR_USERNAME=
# TR_PASSWORD=

# ── Aria2（支持 RPC） ──
# ARIA2_HOST=http://localhost:6800
# ARIA2_SECRET=your-rpc-secret

# ═══════════════════════════════════════════════════════════════
#  通知渠道
# ═══════════════════════════════════════════════════════════════

# ── Telegram ──
# 创建 Bot: @BotFather 获取 token
# 群组/频道 ID: @userinfobot 或 @getidsbot
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# ── 微信通知（Server酱） ──
# 申请地址: https://sct.ftqq.com/
# WECHAT_SENDKEY=your-sendkey

# ── Bark（iOS） ──
# BARK_SERVER=https://api.day.app
# BARK_KEY=your-bark-key

# ── 邮件通知 ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@mediastation.local
# SMTP_TO=admin@example.com

# ── Webhook（通用） ──
# WEBHOOK_URL=https://your-webhook.com/endpoint
# WEBHOOK_METHOD=POST

# ═══════════════════════════════════════════════════════════════
#  转码与播放
# ═══════════════════════════════════════════════════════════════

# ── 硬件加速（自动检测，手动指定） ──
# 可选值: auto / qsv / vaapi / nvenc / videotoolbox / none
# Intel GPU → qsv
# AMD GPU/APU → vaapi
# NVIDIA GPU → nvenc
# Apple Silicon → videotoolbox
# 无硬件加速 → none
HW_ACCEL=auto

# ── FFmpeg/FFprobe 路径（使用宿主机安装的版本） ──
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# ── 最大并发转码任务数 ──
MAX_TRANSCODE_JOBS=2

# ── 转码质量预设 ──
# ultrafast / superfast / veryfast / faster / fast / medium / slow / slower / veryslow
TRANSCODE_PRESET=medium

# ── 码率控制 ──
# CRF 值（数值越小质量越高，文件越大）
TRANSCODE_CRF=23

# ═══════════════════════════════════════════════════════════════
#  媒体目录配置
# ═══════════════════════════════════════════════════════════════

# ── 电影目录 ──
MOVIES_DIR=./media/movies

# ── 电视剧目录 ──
TV_DIR=./media/tv

# ── 动漫目录 ──
ANIME_DIR=./media/anime

# ── 下载目录（需与下载客户端的下载目录一致） ──
DOWNLOADS_DIR=./downloads

# ── 字幕目录 ──
SUBTITLES_DIR=./subtitles

# ═══════════════════════════════════════════════════════════════
#  订阅与站点配置
# ═══════════════════════════════════════════════════════════════

# ── RSS 更新间隔（秒） ──
RSS_INTERVAL=1800

# ── 订阅搜索间隔（秒） ──
SUBSCRIBE_INTERVAL=3600

# ── 下载完成后自动整理 ──
# AUTO_ORGANIZE=true

# ── 自动删除已完成种子（天数，0=禁用） ──
# SEEDING_TIME_LIMIT=30

# ═══════════════════════════════════════════════════════════════
#  系统与性能
# ═══════════════════════════════════════════════════════════════

# ── 时区 ──
TZ=Asia/Shanghai

# ── 日志级别 ──
# DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# ── 日志文件大小限制（MB） ──
LOG_MAX_SIZE=10

# ── 日志备份数量 ──
LOG_BACKUP_COUNT=3

# ── 代理设置 ──
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1

# ═══════════════════════════════════════════════════════════════
#  安全与网络
# ═══════════════════════════════════════════════════════════════

# ── CORS 配置 ──
# CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# ── API 速率限制（请求/分钟） ──
# RATE_LIMIT=60

# ── 是否允许注册 ──
# ALLOW_REGISTER=false

# ── 默认用户角色 ──
# user / admin
# DEFAULT_ROLE=user
