# MediaStation 前端环境变量示例
# 复制此文件为 .env 并修改对应值

# === API 配置 ===
VITE_API_BASE_URL=http://localhost:3002
VITE_API_PREFIX=/api

# === 应用配置 ===
VITE_APP_NAME=MediaStation
VITE_APP_VERSION=1.0.0

# === 功能开关 ===
VITE_ENABLE_DEBUG=false
VITE_ENABLE_ANALYTICS=false

# === 主题配置 ===
VITE_DEFAULT_THEME=system
