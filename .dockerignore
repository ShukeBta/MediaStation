# ===========================================
# Docker 构建忽略文件
# ===========================================

# Git
.git
.gitignore
.gitattributes

# 环境变量 (必须排除，防止敏感信息泄露)
**/.env
.env
.env.*
*.env
**/.env.local
**/.env.production
**/.env.*.local

# 敏感配置文件
**/secrets.json
**/credentials.json
**/*.pem
**/*.key
**/id_rsa*

# 日志
*.log
logs/
*.log.*
**/*.log
**/logs/

# 数据库 (禁止打包)
**/*.db
**/*.db-*
**/*.sqlite
**/*.sqlite3
data/
**/data/
backend/data/

# 缓存目录
**/cache/
**/__pycache__/
**/.pytest_cache/
**/node_modules/.cache/

# Python
__pycache__/
*.py[cod]
venv/
.venv/
*.egg-info/
.pytest_cache/
.tox/

# Node.js (在 frontend 里分别处理)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# 临时文件
*.tmp
*.temp
*.bak
*.backup
*-backup/
nul

# 测试文件和敏感数据
tests/
test/
test_*.py
*_test.py
*test*.py
cookies.txt
*.test.js
*.spec.js

# 文档
*.md
!README.md
docs/

# 备份
backup_md/
backup/

# Docker 文件本身 (不要递归)
docker-compose*.yml
Dockerfile*
.dockerignore

# 工作区配置
.workbuddy/
.kiro/

# 后端本地数据 (运行时生成)
backend/backend*.log
backend/*.pid
backend/app.db

# 仓库截图
screenshots/
