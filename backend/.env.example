# MediaStation 后端环境变量示例
# 复制此文件为 .env 并修改对应值

# === 应用配置 ===
APP_NAME=MediaStation
APP_PORT=3001
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-string
DATA_DIR=./data

# === 数据库 ===
# 默认使用 SQLite，无需配置
# 如需 PostgreSQL：
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mediastation

# === TMDb API ===
# 申请地址: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key
TMDB_LANGUAGE=zh-CN

# === 豆瓣（可选） ===
# DOUBAN_COOKIE=

# === Bangumi（可选） ===
# BANGUMI_TOKEN=

# === qBittorrent ===
QB_HOST=http://127.0.0.1:8080
QB_USERNAME=admin
QB_PASSWORD=adminadmin

# === Transmission ===
# TR_HOST=http://127.0.0.1:9091
# TR_USERNAME=
# TR_PASSWORD=

# === Telegram 通知（可选） ===
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# === 微信推送（可选，Server酱） ===
# WECHAT_SENDKEY=

# === Bark 推送（可选，iOS） ===
# BARK_SERVER=
# BARK_KEY=

# === FFmpeg ===
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
HW_ACCEL=auto
MAX_TRANSCODE_JOBS=2
