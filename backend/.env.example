# MediaStation 后端环境变量示例
# 复制此文件为 .env 并修改对应值

# === 应用配置 ===
APP_NAME=MediaStation
APP_PORT=3001
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-string
DATA_DIR=./data

# === 媒体目录（可选，用逗号分隔多个绝对路径） ===
# 部署后请将此项配置为服务器上实际的媒体存储位置。
# 留空则使用 DATA_DIR/media/{movies,tv,anime} 作为默认目录。
#
# Linux / Docker 示例：
#   MEDIA_DIRS=/media/movies,/mnt/nas/tv,/mnt/nas/anime
#
# Windows 本地运行示例（使用反斜杠或正斜杠均可）：
#   MEDIA_DIRS=D:\Movies,E:\TV Shows,F:\Anime
#   MEDIA_DIRS=D:/Movies,E:/TV Shows,F:/Anime
#
# Docker Compose 挂载示例（将宿主机目录挂载到容器内）：
#   volumes:
#     - /host/movies:/movies
#     - /host/tv:/tv
#   environment:
#     MEDIA_DIRS=/movies,/tv
#
MEDIA_DIRS=

# === 数据库 ===
# 默认使用 SQLite，无需配置
# 如需 PostgreSQL：
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mediastation

# === TMDb API ===
# 申请地址: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key
TMDB_LANGUAGE=zh-CN

# === 豆瓣（可选） ===
# DOUBAN_COOKIE=

# === Bangumi（可选） ===
# BANGUMI_TOKEN=

# === qBittorrent ===
QB_HOST=http://127.0.0.1:8080
QB_USERNAME=admin
QB_PASSWORD=adminadmin

# === Transmission ===
# TR_HOST=http://127.0.0.1:9091
# TR_USERNAME=
# TR_PASSWORD=

# === Telegram 通知（可选） ===
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# === 微信推送（可选，Server酱） ===
# WECHAT_SENDKEY=

# === Bark 推送（可选，iOS） ===
# BARK_SERVER=
# BARK_KEY=

# === FFmpeg ===
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
HW_ACCEL=auto
MAX_TRANSCODE_JOBS=2
